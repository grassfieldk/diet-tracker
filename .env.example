# ベース URL
APP_BASE_URL=http://localhost:3000

# Auth0
# Auth0 Dashboard > Applications > your app > Settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
# openssl rand -hex 32 などで生成
AUTH0_SECRET=your_random_secret_at_least_32_chars

# Prisma Postgres
# Prisma Data Platform > your project > Connection string で確認
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Gemini（未設定の場合、モック使用）
# Google AI Studio > API Keys
GEMINI_API_KEY=
# 使用するモデル名（デフォルト: gemini-2.5-flash）
GEMINI_MODEL=
